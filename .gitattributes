# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyi text eol=lf

# JavaScript/React files
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Markdown files
*.md text eol=lf
*.markdown text eol=lf

# Shell scripts
*.sh text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Config files
.env* text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf

# Binary files (no modification)
*.db binary
*.rdb binary
*.dump binary
*.pyc binary
*.so binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
