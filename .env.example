# Telegram Bot API tokens (BotFather)
PUBLIC_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
PRIVATE_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew22

# Optional Pyrogram userbot credentials (if usas userbot.py)
API_ID=123456
API_HASH=abcdefghijklmnopqrstuvwxyz123456

# Redis for queue/estado
REDIS_URL=redis://redis:6379/0

# DB (opcional)
DATABASE_URL=postgresql://telegram:changeme@db:5432/telegram

# Webhook (si usas webhook mode)
WEBHOOK_URL=https://bot.example.com/webhook
WEBHOOK_SECRET_TOKEN=super-secret-webhook-token

# Antifraud tuning
RAID_THRESHOLD=20
RAID_WINDOW=300

# Seguridad adicional
ADMIN_IDS=123456789,987654321
LOG_LEVEL=INFO
